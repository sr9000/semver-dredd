FROM python:3.11-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work

RUN python -m pip install --upgrade pip \
    && python -m pip install --no-cache-dir build twine PyYAML

COPY scripts/package_install_check.sh /usr/local/bin/package_install_check.sh
RUN chmod +x /usr/local/bin/package_install_check.sh

ENTRYPOINT ["/usr/local/bin/package_install_check.sh"]